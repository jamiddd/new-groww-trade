# Site address sourced from $DOMAIN.
# - For HTTPS via a real domain: set DOMAIN=your.domain.com in deploy/.env
# - For plain HTTP on the droplet IP: set DOMAIN=:80 (default fallback)
#   Caddy treats `:80` as "listen on port 80, all hostnames, plain HTTP".

{$DOMAIN::80} {
    encode zstd gzip

    # Backend (FastAPI under /api/*)
    handle /api/* {
        reverse_proxy backend:8001
    }

    # Optional: serve a static web build of the Expo frontend.
    # Drop `expo export --platform web` output into /srv and uncomment.
    # handle {
    #     root * /srv
    #     try_files {path} /index.html
    #     file_server
    # }
}
